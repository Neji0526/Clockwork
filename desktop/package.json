{
  "name": "clockwork-desktop",
  "productName": "ClockWork",
  "version": "1.0.3",
  "description": "ClockWork — transparent time and work tracker for virtual assistants. Cross-platform desktop app (migrated from the Chrome extension).",
  "author": {
    "name": "ClockWork",
    "email": "support@clockwork.app"
  },
  "license": "UNLICENSED",
  "private": true,
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
